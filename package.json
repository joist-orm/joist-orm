{
  "version": "2.0.3",
  "name": "joist",
  "scripts": {
    "build": "tsgo --build && yarn workspaces foreach --all --exclude joist --exclude joist-docs --topological-dev exec sh -c 'yarn run -T tsc-alias-bin -p \"$PWD/tsconfig.json\"'",
    "semantic-release": "semantic-release",
    "publish-next": "./scripts/publish-next.sh",
    "trust-npm-circleci": "node ./scripts/trust-npm-circleci.mjs",
    "migrate": "yarn workspaces foreach --all run migrate",
    "codegen": "yarn workspaces foreach --all run codegen",
    "format": "yarn workspaces foreach --all run format",
    "start": "yarn mprocs",
    "test": "yarn workspaces foreach --all run test",
    "docker": "docker-compose build",
    "db": "docker compose up db --wait && docker compose exec db ./reset.sh && yarn migrate && yarn codegen",
    "psql": "docker compose exec db ./console.sh",
    "tsc-alias-bin": "yarn tsc-alias"
  },
  "private": true,
  "workspaces": [
    "docs",
    "packages/codegen",
    "packages/core",
    "packages/drivers/bun-pg",
    "packages/graphql-codegen",
    "packages/graphql-resolver-utils",
    "packages/knex",
    "packages/migration-utils",
    "packages/orm",
    "packages/utils",
    "packages/test-utils",
    "packages/tests/bun",
    "packages/tests/bun-sql-pg",
    "packages/tests/integration",
    "packages/tests/schema-misc",
    "packages/tests/esm",
    "packages/tests/immediate-foreign-keys",
    "packages/tests/number-ids",
    "packages/tests/untagged-ids",
    "packages/tests/uuid-ids",
    "packages/tests/temporal"
  ],
  "devDependencies": {
    "@semantic-release/changelog": "^6.0.3",
    "@semantic-release/commit-analyzer": "^13.0.1",
    "@semantic-release/exec": "^7.1.0",
    "@semantic-release/git": "^10.0.1",
    "@semantic-release/github": "^12.0.8",
    "@semantic-release/release-notes-generator": "^14.1.1",
    "@tsconfig/node20": "^20.1.9",
    "@typescript/native-preview": "7.0.0-dev.20260618.1",
    "env-cmd": "^11.0.0",
    "expect-type": "^1.3.0",
    "mprocs": "^0.9.2",
    "semantic-release": "^25.0.3",
    "tsc-alias": "^1.8.17"
  },
  "dependencies": {
    "typescript": "5.9.3"
  },
  "resolutions": {
    "marked": "15.0.8"
  },
  "packageManager": "yarn@4.17.0"
}
