{
  "name": "joist-tests-integration",
  "version": "1.24.0",
  "license": "MIT",
  "private": true,
  "repository": {
    "type": "git",
    "url": "https://github.com/joist-orm/joist-orm.git",
    "directory": "packages/tests/integration"
  },
  "scripts": {
    "migrate": "DECAMELIZE=false env-cmd tsx ../../migration-utils",
    "test": "yarn test-stock && yarn test-preloading",
    "test-stock": "PLUGINS= jest --runInBand --logHeapUsage",
    "test-preloading": "PLUGINS=join-preloading jest --runInBand --logHeapUsage",
    "format": "prettier --ignore-path ../../../.prettierignore --ignore-path ../../.prettierignore --write '{schema,migrations,src}/**/*.{ts,js,tsx,jsx,graphql}'",
    "codegen": "env-cmd tsx ../../codegen && graphql-codegen --config graphql-codegen.mjs",
    "docker:up": "docker compose up -d db",
    "docker:reset": "docker compose exec db ./reset.sh"
  },
  "dependencies": {
    "joist-graphql-resolver-utils": "workspace:*",
    "joist-orm": "workspace:*",
    "knex": "3.2.10",
    "mitata": "^1.0.34"
  },
  "devDependencies": {
    "@graphql-codegen/cli": "^7.1.3",
    "@graphql-tools/graphql-file-loader": "^8.1.14",
    "@graphql-tools/load": "^8.1.10",
    "@homebound/graphql-typescript-possible-types": "^2.19.0",
    "@homebound/graphql-typescript-resolver-scaffolding": "^2.49.0",
    "@homebound/graphql-typescript-scalar-type-policies": "^2.14.0",
    "@homebound/graphql-typescript-simple-resolvers": "^1.58.0",
    "@swc/core": "^1.15.43",
    "@swc/jest": "^0.2.39",
    "@types/jest": "^30.0.0",
    "@types/node": "^26.0.1",
    "env-cmd": "^11.0.0",
    "graphql": "^16.14.2",
    "jest": "30.4.2",
    "jest-junit": "^17.0.0",
    "joist-codegen": "workspace:*",
    "joist-core": "workspace:*",
    "joist-graphql-codegen": "workspace:*",
    "joist-knex": "workspace:*",
    "joist-migration-utils": "workspace:*",
    "joist-test-utils": "workspace:*",
    "joist-utils": "workspace:*",
    "kelonio": "^0.12.0",
    "postgres": "^3.4.9",
    "prettier": "^3.8.4",
    "prettier-plugin-organize-imports": "^4.3.0",
    "superstruct": "^2.0.2",
    "ts-jest": "^29.4.11",
    "tsconfig-paths": "^4.2.0",
    "tsx": "^4.22.4",
    "typescript": "6.0.3",
    "zod": "^4.4.3"
  }
}
